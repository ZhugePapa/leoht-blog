---
import type { NumberedCard } from "../lib/cards";
import { cardSlug } from "../lib/cards";
import { base } from "../lib/base";
import { getDomain } from "../lib/domains";

interface Props {
  card: NumberedCard;
  showSummary?: boolean;
}

const { card, showSummary = true } = Astro.props;
const slug = cardSlug(card);
const href = `${base}c/${slug}`;
const typeLabel = card.data.type.charAt(0).toUpperCase() + card.data.type.slice(1);
const domainName = getDomain(card.data.domain)?.name ?? card.data.domain ?? "general";
const typeTopLine = card.data.type === "effect" || card.data.type === "principle" ? "gold" : "charcoal";
const tags = card.data.tags.slice(0, 3).join(" / ");
---

<article class="card" data-top={typeTopLine}>
  <div class="card-head meta">
    <span>{typeLabel}</span>
    <span class="status-stamp">{domainName}</span>
  </div>
  <div class="card-body">
    <h3 class="card-title"><a href={href}>{card.data.title}</a></h3>
    {card.data.summary && <p class="card-sub">{card.data.summary}</p>}
  </div>
  <div class="card-foot meta">
    <span>{tags}</span>
  </div>
</article>

<style>
  .card {
    border: 1px solid var(--rule);
    border-top: 2px solid var(--color-charcoal);
    background: var(--color-card);
    padding: 0;
    transition: background 140ms ease;
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .card[data-top="gold"] {
    border-top-color: var(--color-muted-gold);
  }
  .card:hover {
    background: var(--color-vellum);
  }
  .card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
  }
  .card-body {
    padding: 12px 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    flex: 1;
  }
  .card-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--size-s);
    line-height: 1.25;
    margin: 0;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }
  .card-title a {
    color: var(--color-charcoal);
    text-decoration: none;
    display: block;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }
  .card-title a:hover {
    color: var(--color-vintage-red);
    text-decoration: underline;
  }
  .card-sub {
    font-family: var(--font-body);
    font-style: normal;
    font-size: var(--size-body);
    line-height: 1.65;
    color: var(--color-charcoal-soft);
    margin: 0;
    flex: 1;
  }
  .card-foot {
    padding: 16px 20px;
    border-top: 1px solid var(--rule);
  }
  .card .status-stamp {
    background: var(--color-vintage-red);
    color: #f9f7f2;
    border: 0;
    transform: none;
    box-shadow: none;
    padding: 1px 8px;
    min-height: 28px;
    display: inline-flex;
    align-items: center;
  }
</style>